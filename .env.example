# Environment Configuration Example
# Copy this file to .env and fill in your actual values for production

# Flask Environment (development, testing, production)
FLASK_ENV=production

# Flask Debug Mode (should be False in production)
FLASK_DEBUG=False

# Secret key for session management (CHANGE THIS IN PRODUCTION!)
SECRET_KEY=your-production-secret-key-here-change-this

# Google Gemini API Key (optional - for GenAI features)
GOOGLE_API_KEY=your-google-api-key-here

# Database Path (optional - defaults to hiring.db in root)
DATABASE_PATH=/path/to/your/hiring.db

# Upload Folder (optional - defaults to uploads/ in root)
UPLOAD_FOLDER=/path/to/uploads

# Security Settings
SESSION_COOKIE_SECURE=True
PREFERRED_URL_SCHEME=https

# Port (optional - default is 5000)
PORT=5000

# Logging Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
